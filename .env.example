# NKZ BioOrchestrator — local development environment
# Copy to .env and fill in values. Never commit .env.

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bioorchestrator

# ── Backend ────────────────────────────────────────────────────────────────────
AUTH_DISABLED=true
AUTH_STRICT=false
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── IkerKeta data directories ──────────────────────────────────────────────────
# Path to IkerKeta processed output (JSON-LD files for graph ingestion)
IKERKETA_DATA_DIR=./data/processed

# ── DAD-IS (FAO) ────────────────────────────────────────────────────────────────
# DADIS_API_URL=https://us-central1-fao-dadis-dev.cloudfunctions.net/api/v1
# DADIS_API_TOKEN=

# ── IUCN Red List ──────────────────────────────────────────────────────────────
# IUCN_API_URL=https://api.iucnredlist.org/api/v4
# IUCN_API_TOKEN=

# ── Keycloak (production only) ─────────────────────────────────────────────────
# KEYCLOAK_JWKS_URL=https://auth.robotika.cloud/realms/nekazari/protocol/openid-connect/certs
# KEYCLOAK_CLIENT_ID=nekazari-frontend
